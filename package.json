{
  "name": "iconix",
  "version": "0.1.0",
  "description": "Cross-framework SVG icon library — one source of truth, native rendering for web (Custom Element), React Native, LynxJS, and VS Code.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./web": {
      "import": {
        "types": "./dist/web.d.ts",
        "default": "./dist/web.js"
      },
      "require": {
        "types": "./dist/web.d.cts",
        "default": "./dist/web.cjs"
      }
    },
    "./svg/*": "./svg/*"
  },
  "files": [
    "dist",
    "svg"
  ],
  "sideEffects": false,
  "scripts": {
    "build:icons": "bun run scripts/build-icons.ts",
    "build": "bun run build:icons && tsup",
    "clean": "rm -rf dist svg src/core/icons.gen.ts",
    "prepublishOnly": "bun run build",
    "test": "bun run build && bun test/smoke.mjs"
  },
  "keywords": [
    "icons",
    "svg",
    "icon-library",
    "react-native",
    "lynxjs",
    "web-components"
  ],
  "author": "Gohit X (bastndev)",
  "license": "MIT",
  "homepage": "https://gohit.xyz/package/iconix",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bastndev/iconix.git"
  },
  "bugs": {
    "url": "https://github.com/bastndev/iconix/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsup": "^8",
    "typescript": "^5"
  }
}
